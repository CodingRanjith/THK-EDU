# Server
PORT=5000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/techackode_edu

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# Default admin (created on first seed)
ADMIN_EMAIL=admin@techackode.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Techackode Admin

# CORS
CLIENT_URL=http://localhost:5173
