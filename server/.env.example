# =============================================================================
# LOCAL DEVELOPMENT (active — comment out when switching to production)
# =============================================================================
PORT=5000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/techackode_edu

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# Default admin (created on first seed)
ADMIN_EMAIL=admin@techackode.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=Techackode Admin

# CORS
CLIENT_URL=http://localhost:5173

# =============================================================================
# PRODUCTION (commented — uncomment and comment local block above to use)
# =============================================================================
# PORT=5000
# NODE_ENV=production
#
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/techackode_edu
#
# JWT_SECRET=your-long-random-production-secret
# JWT_EXPIRES_IN=7d
#
# ADMIN_EMAIL=admin@techackode.com
# ADMIN_PASSWORD=your-secure-production-password
# ADMIN_NAME=Techackode Admin
#
# CLIENT_URL=https://your-production-domain.com
