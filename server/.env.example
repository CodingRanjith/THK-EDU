# =============================================================================
# LOCAL DEVELOPMENT
# =============================================================================
PORT=5000
NODE_ENV=development
# NODE_ENV=production

# Supabase project
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
SUPABASE_SECRET_KEY=your-supabase-secret-key
SUPABASE_JWKS_URL=https://your-project-ref.supabase.co/auth/v1/.well-known/jwks.json

# PostgreSQL (Supavisor pooler — IPv4 + SSL; direct db.* host is IPv6-only)
DATABASE_URL=postgresql://postgres.your-project-ref:YOUR_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# Default admin (created on first seed)
ADMIN_EMAIL=admin@techackode.com
ADMIN_PASSWORD=change-this-admin-password
ADMIN_NAME=Techackode Admin

# CORS (comma-separated — local + production Netlify/custom domains)
# Also set CLIENT_URL on Render/hosting and restart the API after deploy.
CLIENT_URL=http://localhost:5173,https://admin.techackode.com,https://rg-admin.netlify.app
